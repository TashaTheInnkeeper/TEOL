    <div class="option-wrap"><input id="option_3" class="radio-answer" name="answer" type="radio" value="3"/><label for="option_3">37 cm</label></div>
    <div class="option-wrap"><input id="option_4" class="radio-answer" name="answer" type="radio" value="4"/><label for="option_4">39 cm</label></div>
    <div class="option-wrap"><input id="option_5" class="radio-answer" name="answer" type="radio" value="5"/><label for="option_5">40 cm</label></div>
</div>
				
